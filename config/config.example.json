{
  "app": {
    "name": "截图答题工具",
    "version": "1.1.0"
  },
  "hotkey": {
    "modifiers": "alt+shift",
    "key": "q"
  },
  "ai": {
    "model": "deepseek-v4-flash",
    "api_key": "your-api-key-here",
    "api_base": "https://api.deepseek.com",
    "temperature": 0.3,
    "max_tokens": 400
  },
  "ocr": {
    "language": "auto",
    "confidence_threshold": 0.5
  },
  "capture": {
    "hide_window": true,
    "delay_ms": 300,
    "region": null
  },
  "display": {
    "show_result_popup": true,
    "notifications_enabled": true
  }
}
