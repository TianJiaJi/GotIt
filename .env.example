# LiteLLM 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# AI模型配置（支持多种模型）
# 选项: gpt-3.5-turbo, gpt-4, claude-3-haiku, claude-3-sonnet, 等
LITELLM_MODEL=gpt-3.5-turbo

# API密钥（根据使用的模型设置对应的密钥）
# OpenAI API密钥
LITELLM_API_KEY=your_openai_api_key_here

# API基础URL（可选，用于代理或自定义API端点）
# LITELLM_API_BASE=https://api.openai.com/v1

# 示例配置：
# 1. 使用OpenAI GPT-3.5:
#    LITELLM_MODEL=gpt-3.5-turbo
#    LITELLM_API_KEY=sk-xxxxxxxxxxxxx

# 2. 使用Anthropic Claude:
#    LITELLM_MODEL=claude-3-haiku
#    LITELLM_API_KEY=sk-ant-xxxxxxxxxxxxx

# 3. 使用本地API或代理:
#    LITELLM_MODEL=gpt-3.5-turbo
#    LITELLM_API_BASE=http://localhost:8000